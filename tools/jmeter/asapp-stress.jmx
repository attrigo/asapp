                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">int n = (vars.get('taskIdsCount') ?: '0') as int
if (n &lt; 1) { vars.put('taskIdsCsv',''); return }
int from = Math.max(1, n - 49)
def ids = (from..n).collect { vars.get('taskIds_' + it) }.findAll { it != null }
vars.put('taskIdsCsv', ids.join(','))</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
