                <stringProp name="script">int n = (vars.get('taskIdsCount') ?: '0') as int
n++; vars.put('taskIdsCount', n.toString()); vars.put('taskIds_' + n, vars.get('taskId'))</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
