              <stringProp name="3">task_${__threadNum}_upd_${__Random(1,1000000)}</stringProp>
            </collectionProp>
          </collectionProp>
          <boolProp name="UserParameters.per_iteration">true</boolProp>
        </UserParameters>
        <hashTree/>
