#!/usr/bin/env bash

# Define color codes
RED='\033[0;31m'      # Errors
GREEN='\033[0;32m'    # Success
YELLOW='\033[1;33m'   # Warnings/Instructions
BLUE='\033[0;34m'     # Informational messages and commands
NC='\033[0m'          # No Color

# Shell exits with error if any command exits with a non-zero status
set -e

# Define file extensions to check (keep in sync!)
FILE_EXTENSIONS='java|xml|jmx|yml|yaml|properties|txt|md|adoc|sh|sql|json|js|ts|css|html'

echo "Checking line endings of staged files are Unix (LF):"

# Get list of staged text files, NUL-delimited so filenames containing spaces
# survive intact (unquoted word-splitting would drop them: a false pass).
mapfile -d '' -t staged_files < <(git diff --cached --name-only --diff-filter=ACM -z | grep -zE "\.($FILE_EXTENSIONS)$")

if [ "${#staged_files[@]}" -gt 0 ]; then
    # Check for CRLF line endings
    crlf_files=""
    for file in "${staged_files[@]}"; do
        # Inspect the staged blob (index), not the working-tree copy, so the
        # check reflects exactly what is being committed. Count raw CR bytes
        # rather than grep for them: grep strips \r as a line terminator under
        # Git-Bash/MSYS, which would silently miss CRLF.
        cr_count=$(git show ":$file" 2>/dev/null | tr -cd '\r' | wc -c | tr -d '[:space:]')
        if [ "$cr_count" -gt 0 ]; then
            crlf_files="$crlf_files\n  $file"
        fi
    done

    if [ -n "$crlf_files" ]; then
        echo -e "${RED}ERROR: The following files contain Windows line endings (CRLF):${NC}"
        echo -e "${RED}$crlf_files${NC}"
        echo ""
        echo -e "${YELLOW}Please convert them to Unix line endings (LF) before committing.${NC}"
        echo "To fix a specific file:"
        echo -e "${BLUE}  dos2unix <filename>${NC}"
        echo "To fix all files in the project:"
        echo -e "${BLUE}  git ls-files | grep -E '\\.(java|xml|jmx|yml|yaml|properties|txt|md|adoc|sh|sql|json|js|ts|css|html)$' | xargs dos2unix${NC}"
        exit 1
    fi

    echo -e "${GREEN}[OK] All staged files use Unix line endings (LF).${NC}"
else
    echo -e "${GREEN}[OK] No text files to check.${NC}"
fi

echo ""

echo "Checking code style:"

./gradlew --quiet spotlessCheck

echo ""
