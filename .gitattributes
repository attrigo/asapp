# Default for every file: auto-detect text vs binary, normalize text to LF in
# the repo, and force LF in the working tree on all platforms (overrides core.autocrlf).
# Only the exceptions below deviate from LF.
* text=auto eol=lf

# Windows batch
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Keystores/secrets
*.p12 binary
*.jks binary
*.keystore binary
*.pfx binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Archives
*.zip binary
*.gz binary
*.tar binary
